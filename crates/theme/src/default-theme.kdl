backdrop {
    background "#00000060"
}

window {
    background "#121212"
    border "#212121"
    border-width 2
    radius 16
    padding { x 28; y 26 }
    gap 20
    shadow { color "#00000090"; blur 25; spread 10; offset-x 0; offset-y 15 }

    text "#f0f0f2"

    title {
        font "Inter"
        size 24
    }

    icon {
        background "#470aff70"
        text "#efe8ff"
        radius 8
        size 24
        padding { x 10; y 10 }
    }

    description-label {
        text "#737580"
        size 13
    }

    description-value {
        text "#9ea1ab"
        font "monospace"
        size 13
    }

    error {
        text "#eb7578"
        background "#b01d3620"
        radius 6
        size 13
        padding { x 12; y 8 }
    }

    field {
        background "#0f0f0f"
        placeholder "#6b6e78"
        selection "#ffffff60"
        border "#272727"
        border-width 2
        radius 8
        font "monospace"
        size 15
        padding { x 13; y 11 }
        focus { border "#ffffff10"; background "#1d1d1d" }
    }

    reveal {
        text "#808080"
        size 20
    }

    strength {
        background "#272727"
        radius 3
        size 6
    }
    strength-weak { background "#e5484d" }
    strength-medium { background "#e6b340" }
    strength-strong { background "#5cc86b" }

    checkbox {
        background "#0f0f0f"
        text "#9ea1ab"
        border "#272727"
        border-width 1
        radius 4
        size 16
        focus { border "#4d00ff" }
        checked { text "#f0f0f2"; border "#424242" }
    }

    confirm {
        background "#470aff70"
        text "#efe8ff"
        radius 6
        size 13
        padding { x 18; y 9 }
        hover { background "#470affb0" }
        active { background "#470aff95" }
    }

    cancel {
        background "#ffffff05"
        text "#8f8f8f"
        radius 6
        size 13
        padding { x 12; y 9 }
        hover { background "#ffffff12" }
        active { background "#ffffff09" }
    }

    hint-key {
        text "#a5a5a5"
        font "monospace"
        size 12
    }

    hint-word {
        text "#343434"
        size 12
    }
}
